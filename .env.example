# ───────────────────────────────────────────────────────────────────────────
#  Facturación Bee · Plantilla de variables de entorno
#
#  Copia este archivo a `.env` y completa los valores. El archivo `.env` real
#  no se versiona. Las variables se inyectan en build mediante
#  `node scripts/generate-env.mjs` (ejecutado por `pnpm start` y `pnpm build`).
# ───────────────────────────────────────────────────────────────────────────

# Identidad de la aplicación
APP_NAME="Facturación Bee"
APP_ORG="Bee Consultoría y Negocios"
APP_TAGLINE="The power of creating together"
APP_ENV=development

# Tokens de acceso (provistos por el backend de autenticación en producción)
AUTH_TOKEN_ADMIN=
AUTH_TOKEN_USUARIO=
AUTH_SESSION_TTL_MINUTES=30
AUTH_MAX_LOGIN_ATTEMPTS=5

# Parámetros de negocio
BILLING_CLIENT_DEFAULT="Acme Global"
BILLING_RETENTION_RATE=0.125
BILLING_CURRENCY=USD
BILLING_REPORT_CURRENCY=COP
BILLING_PAYMENT_TERM_DAYS=30
INVOICE_PREFIX=BEE
INVOICE_LAST_SEQUENCE=0

# Correos destino
MAIL_CLIENT=
MAIL_APPROVER=
MAIL_PROJECTS=
MAIL_FINANCE=
MAIL_OPERATIONS=

# Repositorio documental
DOC_REPOSITORY_URL=
